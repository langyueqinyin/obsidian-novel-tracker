{
  "name": "obsidian-novel-tracker",
  "version": "0.3.2",
  "description": "Novel plot tracking plugin for Obsidian",
  "main": "main.js",
  "scripts": {
    "dev": "node esbuild.config.mjs",
    "build": "tsc -noEmit -skipLibCheck && node esbuild.config.mjs production",
    "deploy": "npm run build && ./deploy.sh"
  },
  "keywords": ["obsidian", "novel", "writing"],
  "author": "Lucia",
  "license": "MIT",
  "devDependencies": {
    "@types/node": "^20.0.0",
    "builtin-modules": "^3.3.0",
    "esbuild": "^0.21.0",
    "obsidian": "^1.5.7",
    "tslib": "^2.6.0",
    "typescript": "^5.4.0"
  }
}
